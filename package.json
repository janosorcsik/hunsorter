{
	"name": "hunsorter",
	"version": "3.0.0",
	"description": "Sorting text with the Hungarian spelling rules",
	"keywords": [
		"hungarian",
		"sort",
		"typescript"
	],
	"homepage": "https://github.com/janosorcsik/hunsorter#readme",
	"bugs": {
		"url": "https://github.com/janosorcsik/hunsorter/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/janosorcsik/hunsorter.git"
	},
	"license": "MIT",
	"author": "János Orcsik",
	"funding": "https://github.com/janosorcsik/hunsorter?sponsor=1",
	"sideEffects": false,
	"exports": {
		".": {
			"import": {
				"types": "./dist/main.d.mts",
				"default": "./dist/main.mjs"
			},
			"require": {
				"types": "./dist/main.d.cts",
				"default": "./dist/main.cjs"
			}
		}
	},
	"main": "./dist/main.cjs",
	"module": "./dist/main.mjs",
	"unpkg": "./dist/main.iife.js",
	"types": "./dist/main.d.mts",
	"type": "module",
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsdown",
		"format": "biome format --write",
		"lint": "biome lint",
		"prepack": "rm -rf dist && pnpm build",
		"release": "pnpm prepack && release-it",
		"test": "vitest --run"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.0",
		"release-it": "^20.2.0",
		"tsdown": "^0.22.3",
		"typescript": "^6.0.3",
		"vitest": "^4.1.9"
	},
	"publishConfig": {
		"registry": "https://registry.npmjs.org"
	},
	"packageManager": "pnpm@11.8.0"
}
